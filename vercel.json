{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/predict", "dest": "api/index.py" },
    { "src": "/app.js", "dest": "/app.js" },
    { "src": "/training_performance.png", "dest": "/training_performance.png" },
    { "src": "/", "dest": "/index.html" }
  ]
}
